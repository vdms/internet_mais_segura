<!-- Image Credit Component for Unsplash Attribution -->
<!-- Required by Unsplash API Terms of Service -->
<div class="image-credit">
  <a 
    href="https://unsplash.com/@{{ photographer }}?utm_source=internet_mais_segura&utm_medium=referral"
    target="_blank"
    rel="noopener noreferrer"
    class="image-credit-link"
  >
    <span class="image-credit-text">
      Foto de <strong>{{ photographerName }}</strong> no 
      <strong>Unsplash</strong>
    </span>
  </a>
</div>
