{
  "name": "internet-mais-segura",
  "version": "1.0.0",
  "description": "Guia de segurança online para crianças e jovens em Portugal",
  "scripts": {
    "start": "npm-run-all --parallel dev:*",
    "build": "npm-run-all clean build:*",
    "dev:eleventy": "eleventy --serve --quiet",
    "dev:scss": "sass src/assets/scss:_site/assets/css --watch --load-path=node_modules",
    "dev:js": "node scripts/build-js.js --watch",
    "build:eleventy": "eleventy",
    "build:scss": "sass src/assets/scss:_site/assets/css --style=compressed --load-path=node_modules --no-source-map",
    "build:js": "node scripts/build-js.js --minify",
    "build:search": "npx -y pagefind --site _site",
    "clean": "rm -rf _site",
    "preview": "npx -y serve _site"
  },
  "keywords": [
    "segurança",
    "internet",
    "crianças",
    "pais",
    "portugal"
  ],
  "author": "Vicente Sarmento",
  "license": "MIT",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-plugin-rss": "^1.2.0",
    "clean-css": "^5.3.3",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.4",
    "html-minifier-terser": "^7.2.0",
    "luxon": "^3.4.4",
    "markdown-it": "^14.0.0",
    "markdown-it-anchor": "^8.6.7",
    "node-fetch": "^2.7.0",
    "npm-run-all": "^4.1.5",
    "pagefind": "^1.0.4",
    "sass": "^1.69.7"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
