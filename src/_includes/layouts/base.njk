<!DOCTYPE html>
<html lang="pt-PT">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ description or 'Guia de segurança online para proteger crianças e jovens na internet. Recursos e conselhos práticos para pais e encarregados de educação em Portugal.' }}">
  
  <title>{{ title }} | Internet mais segura</title>
  
  <!-- Preconnect to external domains -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Source+Sans+3:wght@300;400;500;600&display=swap" rel="stylesheet">
  
  <!-- Stylesheet -->
  <link rel="stylesheet" href="/assets/css/main.css">
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="{{ ogType or 'website' }}">
  <meta property="og:url" content="{{ page.url }}">
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description or 'Guia de segurança online para crianças e jovens' }}">
  {% if image %}
  <meta property="og:image" content="{{ image }}">
  {% endif %}
  
  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image">
  <meta property="twitter:url" content="{{ page.url }}">
  <meta property="twitter:title" content="{{ title }}">
  <meta property="twitter:description" content="{{ description or 'Guia de segurança online para crianças e jovens' }}">
  {% if image %}
  <meta property="twitter:image" content="{{ image }}">
  {% endif %}
  
  <!-- Theme Color -->
  <meta name="theme-color" content="#0d1f3c">
  
  <!-- RSS Feed -->
  <link rel="alternate" type="application/rss+xml" title="Internet mais segura - Blog" href="/feed.xml">
  
  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/favicon.png">
  
  {% block head %}{% endblock %}
</head>
<body>
  <a href="#main" class="skip-link">Saltar para conteúdo principal</a>
  
  {% include "components/navigation.njk" %}
  
  <main id="main">
    {{ content | safe }}
  </main>
  
  {% include "components/footer.njk" %}
  {% include "components/search-modal.njk" %}
  
  <!-- JavaScript -->
  <script src="/assets/js/main.js" type="module"></script>
  
  {% block scripts %}{% endblock %}
</body>
</html>
