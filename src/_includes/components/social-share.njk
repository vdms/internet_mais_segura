<div class="social-share">
  <span class="social-share-label">Partilhar:</span>
  
  <button 
    class="social-share-button twitter" 
    data-platform="twitter"
    aria-label="Partilhar no Twitter"
    title="Partilhar no Twitter"
  >
    𝕏
  </button>
  
  <button 
    class="social-share-button facebook" 
    data-platform="facebook"
    aria-label="Partilhar no Facebook"
    title="Partilhar no Facebook"
  >
    f
  </button>
  
  <button 
    class="social-share-button linkedin" 
    data-platform="linkedin"
    aria-label="Partilhar no LinkedIn"
    title="Partilhar no LinkedIn"
  >
    in
  </button>
  
  <button 
    class="social-share-button whatsapp" 
    data-platform="whatsapp"
    aria-label="Partilhar no WhatsApp"
    title="Partilhar no WhatsApp"
  >
    📱
  </button>
  
  <button 
    class="social-share-button email" 
    data-platform="email"
    aria-label="Partilhar por email"
    title="Partilhar por email"
  >
    ✉️
  </button>
  
  <button 
    class="social-share-button copy" 
    data-platform="copy"
    aria-label="Copiar link"
    title="Copiar link"
  >
    🔗
  </button>
</div>
